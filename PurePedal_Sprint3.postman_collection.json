{
  "info": {
    "_postman_id": "purepedal-sprint3-2026",
    "name": "PurePedal — Sprint 3 (Scoring + Routes)",
    "description": "Full test suite for Sprint 3: Python scoring service (port 8000) and Node gateway route suggestion/save endpoints (port 3000).\n\n**Setup:**\n1. Start services: `docker-compose up`\n2. Run login → token is auto-saved to `token` variable\n3. Run route suggest → use save route with the returned geometry\n4. Run delete with `saved_route_id` auto-set from save",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:3000",  "type": "string" },
    { "key": "scoring_url",    "value": "http://localhost:8000",  "type": "string" },
    { "key": "token",          "value": "",                       "type": "string" },
    { "key": "saved_route_id", "value": "",                       "type": "string" }
  ],
  "item": [

    {
      "name": "1 · Scoring Service (port 8000)",
      "description": "Hit the Python/FastAPI scoring service directly. No auth required. Useful for verifying the service is up and the scoring math is correct before testing the full gateway flow.",
      "item": [

        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{scoring_url}}/health", "host": ["{{scoring_url}}"], "path": ["health"] },
            "description": "Returns status ok/degraded with postgres + redis sub-checks."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "pm.test('has status field', () => pm.expect(pm.response.json()).to.have.property('status'));",
              "pm.test('has dependencies', () => pm.expect(pm.response.json()).to.have.property('dependencies'));"
            ]}
          }]
        },

        {
          "name": "Score — single route (cache miss → fallback AQI)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routes\": [\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9850, 40.7520],\n          [-73.9845, 40.7460],\n          [-73.9840, 40.7400],\n          [-73.9820, 40.7300],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 5800,\n      \"elevation_gain_m\": 15,\n      \"duration_s\": 1380\n    }\n  ]\n}"
            },
            "description": "Single route. AQI will be fallback (75) if Redis cache is empty — check aqiSourceCacheHitRate in metadata."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('one route returned', () => pm.expect(body.routes).to.have.lengthOf(1));",
              "pm.test('rank is 1', () => pm.expect(body.routes[0].rank).to.equal(1));",
              "pm.test('has score object', () => pm.expect(body.routes[0].score).to.be.an('object'));",
              "pm.test('has metadata', () => pm.expect(body.metadata).to.be.an('object'));",
              "pm.test('sampling interval is 500', () => pm.expect(body.metadata.samplingIntervalM).to.equal(500));",
              "pm.test('aqi samples >= 2', () => pm.expect(body.routes[0].score.aqiSamples.length).to.be.gte(2));"
            ]}
          }]
        },

        {
          "name": "Score — three routes ranked",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routes\": [\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9850, 40.7520],\n          [-73.9845, 40.7460],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 5800,\n      \"elevation_gain_m\": 15,\n      \"duration_s\": 1380\n    },\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9750, 40.7550],\n          [-73.9700, 40.7450],\n          [-73.9650, 40.7350],\n          [-73.9750, 40.7100],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 7200,\n      \"elevation_gain_m\": 30,\n      \"duration_s\": 1700\n    },\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9950, 40.7570],\n          [-74.0050, 40.7400],\n          [-74.0030, 40.7300],\n          [-73.9970, 40.7150],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 9400,\n      \"elevation_gain_m\": 55,\n      \"duration_s\": 2200\n    }\n  ]\n}"
            },
            "description": "Three routes: short+flat, medium, long+hilly. Expect rank 1 = best combined score (by default weights: AQI 60%, Distance 25%, Elevation 15%)."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('three routes returned', () => pm.expect(body.routes).to.have.lengthOf(3));",
              "const ranks = body.routes.map(r => r.rank).sort();",
              "pm.test('ranks are 1 2 3', () => pm.expect(ranks).to.deep.equal([1, 2, 3]));",
              "pm.test('rank 1 has highest final score', () => {",
              "  const r1 = body.routes.find(r => r.rank === 1);",
              "  const r2 = body.routes.find(r => r.rank === 2);",
              "  pm.expect(r1.score.final).to.be.gte(r2.score.final);",
              "});"
            ]}
          }]
        },

        {
          "name": "Score — custom weights (non-normalized)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routes\": [\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9840, 40.7400],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 5800,\n      \"elevation_gain_m\": 20\n    }\n  ],\n  \"weights\": {\n    \"aqi\": 10.0,\n    \"distance\": 3.0,\n    \"elevation\": 2.0\n  }\n}"
            },
            "description": "Weights 10/3/2 don't sum to 1. Service normalises them to 0.667/0.2/0.133. Check the scored result is still 0–100."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const score = pm.response.json().routes[0].score;",
              "pm.test('final score in 0-100', () => {",
              "  pm.expect(score.final).to.be.gte(0);",
              "  pm.expect(score.final).to.be.lte(100);",
              "});"
            ]}
          }]
        },

        {
          "name": "Score — with userId (triggers aqi_history persist)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routes\": [\n    {\n      \"geometry\": {\n        \"type\": \"LineString\",\n        \"coordinates\": [\n          [-73.9855, 40.7580],\n          [-73.9840, 40.7400],\n          [-73.9969, 40.7060]\n        ]\n      },\n      \"distance_m\": 5800,\n      \"elevation_gain_m\": 20\n    }\n  ],\n  \"userId\": \"test-user-123\"\n}"
            },
            "description": "When userId is present, AQI samples are fire-and-forget persisted to aqi_history table. Response is identical — check DB to verify rows were inserted."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));"
            ]}
          }]
        },

        {
          "name": "Score — ❌ empty routes (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": { "mode": "raw", "raw": "{\n  \"routes\": []\n}" },
            "description": "Zero routes — must return 422 Unprocessable Entity."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 422', () => pm.response.to.have.status(422));"
            ]}
          }]
        },

        {
          "name": "Score — ❌ four routes (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{scoring_url}}/score", "host": ["{{scoring_url}}"], "path": ["score"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routes\": [\n    {\"geometry\":{\"type\":\"LineString\",\"coordinates\":[[-73.9,40.7],[-73.8,40.6]]},\"distance_m\":5000,\"elevation_gain_m\":10},\n    {\"geometry\":{\"type\":\"LineString\",\"coordinates\":[[-73.9,40.7],[-73.8,40.6]]},\"distance_m\":5000,\"elevation_gain_m\":10},\n    {\"geometry\":{\"type\":\"LineString\",\"coordinates\":[[-73.9,40.7],[-73.8,40.6]]},\"distance_m\":5000,\"elevation_gain_m\":10},\n    {\"geometry\":{\"type\":\"LineString\",\"coordinates\":[[-73.9,40.7],[-73.8,40.6]]},\"distance_m\":5000,\"elevation_gain_m\":10}\n  ]\n}"
            },
            "description": "Four routes exceeds max of 3 — must return 422."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 422', () => pm.response.to.have.status(422));"
            ]}
          }]
        }

      ]
    },

    {
      "name": "2 · Auth — Get Token",
      "description": "Login to get a JWT. The test script auto-saves `access_token` to the `token` collection variable so all subsequent requests use it automatically.",
      "item": [

        {
          "name": "Login → saves token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your@email.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "description": "Replace email/password with your test account. Token is auto-saved to `token` variable."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "if (body.access_token) {",
              "  pm.collectionVariables.set('token', body.access_token);",
              "  console.log('Token saved to collection variable');",
              "}"
            ]}
          }]
        },

        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/me", "host": ["{{base_url}}"], "path": ["api","v1","me"] },
            "description": "Verify the token works and check subscription_status (free/premium)."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has user id', () => pm.expect(body.id).to.be.a('string'));",
              "pm.test('has subscription_status', () => pm.expect(body.subscription_status).to.be.oneOf(['free','premium','lapsed']));"
            ]}
          }]
        }

      ]
    },

    {
      "name": "3 · Routes — Suggest",
      "description": "POST /api/v1/routes/suggest — calls ORS for route geometries, then scores via the Python service. Requires both the Node gateway (port 3000) and scoring service (port 8000) to be running.",
      "item": [

        {
          "name": "Suggest routes — Times Sq → Brooklyn Bridge",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": {\n    \"lat\": 40.7580,\n    \"lng\": -73.9855\n  },\n  \"destination\": {\n    \"lat\": 40.7061,\n    \"lng\": -73.9969\n  }\n}"
            },
            "description": "Times Square → Brooklyn Bridge (~5.8 km). Returns up to 3 scored routes labelled Cleanest / Alternative / Fastest."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has routes array', () => pm.expect(body.routes).to.be.an('array'));",
              "pm.test('has recommendedRouteId', () => pm.expect(body.recommendedRouteId).to.not.be.null);",
              "pm.test('first route has label', () => pm.expect(body.routes[0]).to.have.property('label'));",
              "pm.test('first route has score', () => pm.expect(body.routes[0]).to.have.property('score'));",
              "pm.test('first route has geometry', () => pm.expect(body.routes[0].geometry).to.be.an('object'));",
              "// Save geometry for use in save-route request",
              "if (body.routes && body.routes.length > 0) {",
              "  pm.collectionVariables.set('last_suggest_route', JSON.stringify(body.routes[0]));",
              "}"
            ]}
          }]
        },

        {
          "name": "Suggest routes — with custom weights (premium)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": {\n    \"lat\": 40.7580,\n    \"lng\": -73.9855\n  },\n  \"destination\": {\n    \"lat\": 40.7061,\n    \"lng\": -73.9969\n  },\n  \"preferences\": {\n    \"weights\": {\n      \"aqi\": 0.2,\n      \"distance\": 0.7,\n      \"elevation\": 0.1\n    }\n  }\n}"
            },
            "description": "Same route but heavily weighted toward distance (0.7). Premium users get custom weights applied; free-tier ignores this and uses stored defaults."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));"
            ]}
          }]
        },

        {
          "name": "Suggest — ❌ missing origin (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": { \"lat\": 40.7061, \"lng\": -73.9969 }\n}"
            },
            "description": "No origin — expect 400."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 400', () => pm.response.to.have.status(400));",
              "pm.test('error mentions origin', () => pm.expect(pm.response.json().error).to.include('origin'));"
            ]}
          }]
        },

        {
          "name": "Suggest — ❌ same location (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\":      { \"lat\": 40.7580, \"lng\": -73.9855 },\n  \"destination\": { \"lat\": 40.7580, \"lng\": -73.9855 }\n}"
            },
            "description": "Origin equals destination (<10m apart) — expect 400."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 400', () => pm.response.to.have.status(400));"
            ]}
          }]
        },

        {
          "name": "Suggest — ❌ destination too far (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\":      { \"lat\": 40.7580, \"lng\": -73.9855 },\n  \"destination\": { \"lat\": 51.5074, \"lng\": -0.1278 }\n}"
            },
            "description": "NYC → London is >100 km — expect 400 with max distance error."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 400', () => pm.response.to.have.status(400));",
              "pm.test('error mentions 100km', () => pm.expect(pm.response.json().error).to.include('100km'));"
            ]}
          }]
        },

        {
          "name": "Suggest — ❌ no auth (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/routes/suggest", "host": ["{{base_url}}"], "path": ["api","v1","routes","suggest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\":      { \"lat\": 40.7580, \"lng\": -73.9855 },\n  \"destination\": { \"lat\": 40.7061, \"lng\": -73.9969 }\n}"
            },
            "description": "No Authorization header — expect 401."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 401', () => pm.response.to.have.status(401));"
            ]}
          }]
        }

      ]
    },

    {
      "name": "4 · Routes — Save & Manage",
      "description": "Save a route, list saved routes, delete a route. The save request auto-stores the returned id in `saved_route_id` for use in the delete request.",
      "item": [

        {
          "name": "Get saved routes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/routes/saved", "host": ["{{base_url}}"], "path": ["api","v1","routes","saved"] },
            "description": "Returns saved routes ordered by created_at DESC. Free users see all their saved routes (up to 3). canSaveMore indicates if they can save another."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has routes array', () => pm.expect(body.routes).to.be.an('array'));",
              "pm.test('has count', () => pm.expect(body.count).to.be.a('number'));",
              "pm.test('has canSaveMore', () => pm.expect(body).to.have.property('canSaveMore'));"
            ]}
          }]
        },

        {
          "name": "Save a route → stores saved_route_id",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/saved", "host": ["{{base_url}}"], "path": ["api","v1","routes","saved"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Morning ride to Brooklyn Bridge\",\n  \"geometry\": {\n    \"type\": \"LineString\",\n    \"coordinates\": [\n      [-73.9855, 40.7580],\n      [-73.9850, 40.7520],\n      [-73.9845, 40.7460],\n      [-73.9840, 40.7400],\n      [-73.9820, 40.7300],\n      [-73.9969, 40.7060]\n    ]\n  },\n  \"distance_m\": 5800,\n  \"elevation_gain_m\": 15,\n  \"aqi_at_save\": 42\n}"
            },
            "description": "Save a route with name, GeoJSON LineString, distance, elevation and AQI snapshot. Returns 201 with the new route id."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('has id', () => pm.expect(body.id).to.be.a('string'));",
              "pm.test('name matches', () => pm.expect(body.name).to.equal('Morning ride to Brooklyn Bridge'));",
              "pm.test('distance_m saved', () => pm.expect(body.distance_m).to.equal(5800));",
              "if (body.id) {",
              "  pm.collectionVariables.set('saved_route_id', body.id);",
              "  console.log('saved_route_id set to', body.id);",
              "}"
            ]}
          }]
        },

        {
          "name": "Save a route — with tags (premium only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/routes/saved", "host": ["{{base_url}}"], "path": ["api","v1","routes","saved"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weekend commute\",\n  \"geometry\": {\n    \"type\": \"LineString\",\n    \"coordinates\": [\n      [-73.9855, 40.7580],\n      [-73.9840, 40.7400],\n      [-73.9969, 40.7060]\n    ]\n  },\n  \"distance_m\": 5800,\n  \"elevation_gain_m\": 15,\n  \"aqi_at_save\": 38,\n  \"tags\": [\"commute\", \"flat\", \"scenic\"]\n}"
            },
            "description": "Tags field: premium users get tags saved; free-tier tags are silently ignored (not an error)."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));"
            ]}
          }]
        },

        {
          "name": "Delete saved route",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/routes/saved/{{saved_route_id}}",
              "host": ["{{base_url}}"],
              "path": ["api","v1","routes","saved","{{saved_route_id}}"]
            },
            "description": "Delete the route saved by the previous request. Uses saved_route_id set automatically."
