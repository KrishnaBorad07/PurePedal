{
  "info": {
    "name": "PurePedal — Sprint 8 Premium Features",
    "_postman_id": "sprint8-premium-features-2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token",   "value": "<your-jwt-token>",     "type": "string" },
    { "key": "routeId", "value": "<saved-route-uuid>",   "type": "string" }
  ],
  "item": [
    {
      "name": "1. Forecast Routing",
      "item": [
        {
          "name": "Suggest route with forecastAt (premium)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/suggest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "suggest"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": { \"lat\": 19.0760, \"lng\": 72.8777 },\n  \"destination\": { \"lat\": 19.1136, \"lng\": 72.8697 },\n  \"forecastAt\": \"2026-05-06T08:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Suggest route — forecastAt too far ahead (>48h) → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/suggest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "suggest"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": { \"lat\": 19.0760, \"lng\": 72.8777 },\n  \"destination\": { \"lat\": 19.1136, \"lng\": 72.8697 },\n  \"forecastAt\": \"2026-05-10T08:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Suggest route — forecastAt in past → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/suggest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "suggest"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": { \"lat\": 19.0760, \"lng\": 72.8777 },\n  \"destination\": { \"lat\": 19.1136, \"lng\": 72.8697 },\n  \"forecastAt\": \"2026-05-03T08:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Suggest route — no forecastAt (live AQI)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/suggest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "suggest"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": { \"lat\": 19.0760, \"lng\": 72.8777 },\n  \"destination\": { \"lat\": 19.1136, \"lng\": 72.8697 }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Exposure Score",
      "item": [
        {
          "name": "GET /me/exposure (premium) → 200",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/me/exposure",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "me", "exposure"]
            }
          }
        },
        {
          "name": "GET /me/exposure (free user) → 403",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/me/exposure",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "me", "exposure"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Departure Forecast",
      "item": [
        {
          "name": "GET departure forecast (premium) → 200",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/saved/{{routeId}}/departure-forecast",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "saved", "{{routeId}}", "departure-forecast"]
            }
          }
        },
        {
          "name": "GET departure forecast — non-existent route → 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/saved/00000000-0000-0000-0000-000000000000/departure-forecast",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "saved", "00000000-0000-0000-0000-000000000000", "departure-forecast"]
            }
          }
        },
        {
          "name": "GET departure forecast (free user) → 403",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/saved/{{routeId}}/departure-forecast",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "routes", "saved", "{{routeId}}", "departure-forecast"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Monthly Health Report",
      "item": [
        {
          "name": "GET monthly report (premium) → 200",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rides/summary/monthly?month=4&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rides", "summary", "monthly"],
              "query": [
                { "key": "month", "value": "4" },
                { "key": "year",  "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "GET monthly report — invalid month → 400",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rides/summary/monthly?month=13&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rides", "summary", "monthly"],
              "query": [
                { "key": "month", "value": "13" },
                { "key": "year",  "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "GET monthly report — missing month → 400",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rides/summary/monthly?year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rides", "summary", "monthly"],
              "query": [
                { "key": "year", "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "GET monthly report — report not yet generated → 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rides/summary/monthly?month=1&year=2025",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rides", "summary", "monthly"],
              "query": [
                { "key": "month", "value": "1" },
                { "key": "year",  "value": "2025" }
              ]
            }
          }
        },
        {
          "name": "GET monthly report (free user) → 403",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rides/summary/monthly?month=4&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rides", "summary", "monthly"],
              "query": [
                { "key": "month", "value": "4" },
                { "key": "year",  "value": "2026" }
              ]
            }
          }
        }
      ]
    }
  ]
}
